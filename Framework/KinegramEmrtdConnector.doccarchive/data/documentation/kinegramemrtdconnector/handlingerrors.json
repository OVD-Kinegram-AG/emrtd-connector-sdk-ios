{"abstract":[{"text":"Learn how to handle errors and edge cases in the eMRTD Connector V2.","type":"text"}],"metadata":{"role":"article","title":"Handling Errors","roleHeading":"Article","modules":[{"name":"KinegramEmrtdConnector"}]},"sections":[],"primaryContentSections":[{"content":[{"level":2,"anchor":"Error-Types","text":"Error Types","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The SDK provides comprehensive error handling through the ","type":"text"},{"code":"EmrtdConnectorError","type":"codeVoice"},{"text":" enum and re-exported ","type":"text"},{"code":"EmrtdReaderError","type":"codeVoice"},{"text":" from KinegramEmrtd.","type":"text"}]},{"level":3,"anchor":"Connection-Errors","text":"Connection Errors","type":"heading"},{"syntax":"swift","code":["do {","    let result = try await connector.validate(with: accessKey)","} catch EmrtdConnectorError.connectionFailed {","    \/\/ WebSocket connection failed","    print(\"Could not connect to server\")","} catch EmrtdConnectorError.connectionTimeout {","    \/\/ Connection timed out (20s iOS limit)","    print(\"Connection timed out - try again\")","} catch EmrtdConnectorError.connectionClosed(let reason) {","    \/\/ Connection closed unexpectedly","    print(\"Connection closed: \\(reason)\")","}"],"type":"codeListing"},{"level":3,"anchor":"NFC-Errors","text":"NFC Errors","type":"heading"},{"syntax":"swift","code":["catch EmrtdConnectorError.nfcNotAvailable(let reason) {","    \/\/ NFC not available on device","    print(\"NFC not available: \\(reason)\")","} catch EmrtdConnectorError.incompleteRead(let missingFiles, let reason) {","    \/\/ Required files could not be read (e.g., NFC interruption)","    print(\"Missing files: \\(missingFiles.joined(separator: \", \"))\")","    print(\"\\(reason)\")","} catch EmrtdReaderError.tagConnectionLost {","    \/\/ User moved passport away","    print(\"Connection lost - hold passport steady\")","} catch EmrtdReaderError.accessControlFailed {","    \/\/ Wrong MRZ\/CAN","    print(\"Access denied - check your access key\")","}"],"type":"codeListing"},{"level":3,"anchor":"Protocol-Errors","text":"Protocol Errors","type":"heading"},{"syntax":"swift","code":["catch EmrtdConnectorError.protocolError(let message) {","    \/\/ Server protocol violation","    print(\"Protocol error: \\(message)\")","} catch EmrtdConnectorError.invalidServerResponse(let details) {","    \/\/ Invalid server response","    print(\"Invalid response: \\(details)\")","}"],"type":"codeListing"},{"level":3,"anchor":"Server-Errors","text":"Server Errors","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The server may close the connection with specific error codes and reasons:","type":"text"}]},{"syntax":"swift","code":["catch EmrtdConnectorError.serverError(let code, let message, let reason) {","    \/\/ The SDK automatically parses known close reasons","    if let reason = reason {","        print(reason.localizedDescription)","        ","        \/\/ You can also check specific reasons","        switch reason {","        case .invalidClientId:","            \/\/ Handle invalid client ID (code 4401)","        case .accessControlFailed:","            \/\/ Wrong MRZ\/CAN (code 4403)","        case .nfcChipCommunicationFailed:","            \/\/ Passport moved away (code 1001)","        default:","            break","        }","    } else {","        \/\/ Fallback to raw message","        print(\"Server error \\(code): \\(message ?? \"\")\")","    }","}"],"type":"codeListing"},{"level":4,"anchor":"Common-Close-Reasons","text":"Common Close Reasons","type":"heading"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Reason","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Code"}]}],[{"type":"paragraph","inlineContent":[{"text":"Solution","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"INVALID_CLIENT_ID"}]}],[{"type":"paragraph","inlineContent":[{"text":"Client ID not recognized","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"4401","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Check your client ID configuration","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"ACCESS_CONTROL_FAILED","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Wrong MRZ\/CAN"}]}],[{"type":"paragraph","inlineContent":[{"text":"4403","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Verify document details","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NFC_CHIP_COMMUNICATION_FAILED"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Lost NFC connection"}]}],[{"type":"paragraph","inlineContent":[{"text":"1001","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Hold passport steady","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"TIMEOUT_WHILE_WAITING_FOR_RESPONSE"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Device took too long"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1001"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Ensure stable connection"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"INVALID_ACCESS_KEY_VALUES"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Invalid MRZ format"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1008"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check date formats (YYMMDD)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SERVER_ERROR"}]}],[{"type":"paragraph","inlineContent":[{"text":"Internal server error","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"1011","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Contact support","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"FILE_READ_ERROR"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Failed to read document file"}]}],[{"type":"paragraph","inlineContent":[{"text":"1011","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Try again"}]}]]],"type":"table","header":"row"},{"level":2,"anchor":"Complete-Error-Handling-Example","text":"Complete Error Handling Example","type":"heading"},{"syntax":"swift","code":["class DocumentValidator {","    func validateDocument() async {","        let connector = EmrtdConnector(","            serverURL: URL(string: \"wss:\/\/server.example.com\/ws2\/validate\")!,","            validationId: UUID().uuidString,","            clientId: \"YOUR-CLIENT-ID\"","        )","        ","        do {","            let result = try await connector.validate(with: accessKey)","            handleSuccess(result)","            ","        } catch EmrtdConnectorError.nfcNotAvailable(let reason) {","            showError(\"NFC is not available: \\(reason)\")","            ","        } catch EmrtdConnectorError.connectionTimeout {","            showError(\"The operation timed out. Please try again and hold your passport steady.\")","            ","        } catch EmrtdConnectorError.incompleteRead(let missingFiles, _) {","            showError(\"Could not read all required data. Missing: \\(missingFiles.joined(separator: \", \")). Please try again and hold passport steady.\")","            ","        } catch EmrtdReaderError.accessControlFailed {","            showError(\"Access denied. Please check your document details.\")","            ","        } catch EmrtdReaderError.tagConnectionLost {","            showError(\"Connection lost. Please hold your passport steady and try again.\")","            ","        } catch EmrtdConnectorError.connectionFailed {","            showError(\"Could not connect to server. Please check your internet connection.\")","            ","        } catch EmrtdConnectorError.serverError(let code, let message, let reason) {","            \/\/ Handle specific server errors with parsed reasons","            if let reason = reason {","                switch reason {","                case .invalidClientId:","                    showError(\"Invalid client ID. Please check your configuration.\")","                case .accessControlFailed:","                    showError(\"Access denied. Please check your document details.\")","                case .invalidAccessKeyValues:","                    showError(\"Invalid document details. Please check the format.\")","                case .nfcChipCommunicationFailed:","                    showError(\"Lost connection to document. Please try again.\")","                default:","                    showError(reason.localizedDescription)","                }","            } else {","                showError(message ?? \"Server error \\(code)\")","            }","            ","        } catch is CancellationError {","            \/\/ User cancelled - no need to show error","            print(\"Operation cancelled by user\")","            ","        } catch {","            showError(\"An unexpected error occurred: \\(error.localizedDescription)\")","        }","    }","}"],"type":"codeListing"},{"level":2,"anchor":"Retry-Strategy","text":"Retry Strategy","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For transient errors, implement retry logic in your application:"}]},{"syntax":"swift","code":["func validateWithRetry(maxAttempts: Int = 3) async throws -> ValidationResult {","    var lastError: Error?","    ","    for attempt in 1...maxAttempts {","        do {","            return try await connector.validate(with: accessKey)","        } catch {","            lastError = error","            ","            \/\/ Don't retry certain errors","            if error is CancellationError ||","               (error as? EmrtdReaderError)?.code == .accessControlFailed {","                throw error","            }","            ","            \/\/ Wait before retry","            if attempt < maxAttempts {","                try await Task.sleep(nanoseconds: 1_000_000_000) \/\/ 1 second","            }","        }","    }","    ","    throw lastError ?? EmrtdConnectorError.unknown","}"],"type":"codeListing"},{"level":2,"anchor":"Timeout-Handling","text":"Timeout Handling","type":"heading"},{"inlineContent":[{"text":"iOS limits NFC sessions to 20 seconds. Handle timeouts gracefully:","type":"text"}],"type":"paragraph"},{"code":["connector.delegate = self","","func connector(_ connector: EmrtdConnector, didUpdateNFCStatus status: NFCProgressStatus) async {","    \/\/ Show progress to user","    updateUI(with: status.alertMessage)","    ","    \/\/ Warn if taking too long","    if status.step == .readingDG2 {","        showWarning(\"Please hold passport steady...\")","    }","}"],"type":"codeListing","syntax":"swift"},{"text":"Error Recovery","anchor":"Error-Recovery","type":"heading","level":2},{"text":"Clean Up After Errors","anchor":"Clean-Up-After-Errors","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"The SDK automatically cleans up on errors, but you can ensure proper cleanup:"}],"type":"paragraph"},{"code":["defer {","    Task {","        await connector.disconnect()","    }","}","","do {","    let result = try await connector.validate(with: accessKey)","    \/\/ Process result","} catch {","    \/\/ Error is thrown after cleanup","    handleError(error)","}"],"type":"codeListing","syntax":"swift"},{"text":"User-Friendly Error Messages","anchor":"User-Friendly-Error-Messages","type":"heading","level":3},{"code":["extension Error {","    var userFriendlyMessage: String {","        switch self {","        case EmrtdConnectorError.nfcNotAvailable:","            return \"This device doesn't support NFC\"","        case EmrtdConnectorError.connectionTimeout:","            return \"Reading took too long. Please try again.\"","        case EmrtdConnectorError.incompleteRead:","            return \"Could not read all required passport data. Please try again.\"","        case EmrtdConnectorError.serverError(_, _, let reason?):","            return reason.localizedDescription","        case EmrtdReaderError.accessControlFailed:","            return \"Could not access passport. Please check the details you entered.\"","        case EmrtdReaderError.tagConnectionLost:","            return \"Lost connection. Please hold your passport still.\"","        default:","            return \"Something went wrong. Please try again.\"","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"text":"Debugging","anchor":"Debugging","type":"heading","level":2},{"inlineContent":[{"text":"Debug logging is automatically enabled in DEBUG builds. The logs will show:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"WebSocket messages"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"State transitions","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"NFC operations","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Error details"}]}]}]},{"text":"Common Issues and Solutions","anchor":"Common-Issues-and-Solutions","type":"heading","level":2},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Error"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cause"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Solution"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"accessControlFailed","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Wrong MRZ\/CAN","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Double-check document details","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"connectionTimeout","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Slow connection or movement","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Use stable WiFi, hold passport steady","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"tagConnectionLost","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Passport moved","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Keep passport still during reading"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"incompleteRead"}]}],[{"type":"paragraph","inlineContent":[{"text":"Required files missing (e.g., DG2)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hold passport steady throughout entire process"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"nfcNotAvailable"}]}],[{"type":"paragraph","inlineContent":[{"text":"NFC disabled or unavailable","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check device settings"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"protocolError"}]}],[{"type":"paragraph","inlineContent":[{"text":"Server compatibility","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Check server version\/configuration","type":"text"}]}]]],"type":"table"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/kinegramemrtdconnector\/handlingerrors"]}],"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/HandlingErrors","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector"]]},"references":{"doc://com.kinegram.ios.emrtdconnector/documentation/KinegramEmrtdConnector":{"abstract":[],"url":"\/documentation\/kinegramemrtdconnector","type":"topic","identifier":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector","role":"collection","kind":"symbol","title":"KinegramEmrtdConnector"}}}