{"metadata":{"role":"article","title":"Handling Errors","roleHeading":"Article","modules":[{"name":"KinegramEmrtdConnector"}]},"kind":"article","primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Error-Types","text":"Error Types"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK provides comprehensive error handling through the "},{"code":"EmrtdConnectorError","type":"codeVoice"},{"type":"text","text":" enum and re-exported "},{"code":"EmrtdReaderError","type":"codeVoice"},{"type":"text","text":" from KinegramEmrtd."}]},{"type":"heading","level":3,"anchor":"Connection-Errors","text":"Connection Errors"},{"type":"codeListing","syntax":"swift","code":["do {","    let result = try await connector.validate(with: accessKey)","} catch EmrtdConnectorError.connectionFailed {","    \/\/ WebSocket connection failed","    print(\"Could not connect to server\")","} catch EmrtdConnectorError.connectionTimeout {","    \/\/ Connection timed out (20s iOS limit)","    print(\"Connection timed out - try again\")","} catch EmrtdConnectorError.connectionClosed(let reason) {","    \/\/ Connection closed unexpectedly","    print(\"Connection closed: \\(reason)\")","}"]},{"type":"heading","level":3,"anchor":"NFC-Errors","text":"NFC Errors"},{"type":"codeListing","syntax":"swift","code":["catch EmrtdConnectorError.nfcNotAvailable(let reason) {","    \/\/ NFC not available on device","    print(\"NFC not available: \\(reason)\")","} catch EmrtdConnectorError.incompleteRead(let missingFiles, let reason) {","    \/\/ Required files could not be read (e.g., NFC interruption)","    print(\"Missing files: \\(missingFiles.joined(separator: \", \"))\")","    print(\"\\(reason)\")","} catch EmrtdReaderError.tagConnectionLost {","    \/\/ User moved passport away","    print(\"Connection lost - hold passport steady\")","} catch EmrtdReaderError.accessControlFailed {","    \/\/ Wrong MRZ\/CAN","    print(\"Access denied - check your access key\")","}"]},{"type":"heading","level":3,"anchor":"Protocol-Errors","text":"Protocol Errors"},{"type":"codeListing","syntax":"swift","code":["catch EmrtdConnectorError.protocolError(let message) {","    \/\/ Server protocol violation","    print(\"Protocol error: \\(message)\")","} catch EmrtdConnectorError.invalidServerResponse(let details) {","    \/\/ Invalid server response","    print(\"Invalid response: \\(details)\")","}"]},{"type":"heading","level":3,"anchor":"Server-Errors","text":"Server Errors"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The server may close the connection with specific error codes and reasons:"}]},{"type":"codeListing","syntax":"swift","code":["catch EmrtdConnectorError.serverError(let code, let message, let reason) {","    \/\/ The SDK automatically parses known close reasons","    if let reason = reason {","        print(reason.localizedDescription)","        ","        \/\/ You can also check specific reasons","        switch reason {","        case .invalidClientId:","            \/\/ Handle invalid client ID (code 4401)","        case .accessControlFailed:","            \/\/ Wrong MRZ\/CAN (code 4403)","        case .nfcChipCommunicationFailed:","            \/\/ Passport moved away (code 1001)","        default:","            break","        }","    } else {","        \/\/ Fallback to raw message","        print(\"Server error \\(code): \\(message ?? \"\")\")","    }","}"]},{"type":"heading","level":4,"anchor":"Common-Close-Reasons","text":"Common Close Reasons"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Reason"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Code","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Solution"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"INVALID_CLIENT_ID"}]}],[{"type":"paragraph","inlineContent":[{"text":"Client ID not recognized","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4401"}]}],[{"type":"paragraph","inlineContent":[{"text":"Check your client ID configuration","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"ACCESS_CONTROL_FAILED","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Wrong MRZ\/CAN"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"4403"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify document details"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NFC_CHIP_COMMUNICATION_FAILED"}]}],[{"type":"paragraph","inlineContent":[{"text":"Lost NFC connection","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"1001","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hold passport steady"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"TIMEOUT_WHILE_WAITING_FOR_RESPONSE"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Device took too long"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1001"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Ensure stable connection"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"INVALID_ACCESS_KEY_VALUES","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Invalid MRZ format","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"1008","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check date formats (YYMMDD)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SERVER_ERROR"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Internal server error"}]}],[{"type":"paragraph","inlineContent":[{"text":"1011","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Contact support"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"FILE_READ_ERROR","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Failed to read document file","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1011"}]}],[{"type":"paragraph","inlineContent":[{"text":"Try again","type":"text"}]}]]]},{"anchor":"Complete-Error-Handling-Example","text":"Complete Error Handling Example","level":2,"type":"heading"},{"code":["class DocumentValidator {","    func validateDocument() async {","        let connector = EmrtdConnector(","            serverURL: URL(string: \"wss:\/\/server.example.com\/ws2\/validate\")!,","            validationId: UUID().uuidString,","            clientId: \"YOUR-CLIENT-ID\"","        )","        ","        do {","            let result = try await connector.validate(with: accessKey)","            handleSuccess(result)","            ","        } catch EmrtdConnectorError.nfcNotAvailable(let reason) {","            showError(\"NFC is not available: \\(reason)\")","            ","        } catch EmrtdConnectorError.connectionTimeout {","            showError(\"The operation timed out. Please try again and hold your passport steady.\")","            ","        } catch EmrtdConnectorError.incompleteRead(let missingFiles, _) {","            showError(\"Could not read all required data. Missing: \\(missingFiles.joined(separator: \", \")). Please try again and hold passport steady.\")","            ","        } catch EmrtdReaderError.accessControlFailed {","            showError(\"Access denied. Please check your document details.\")","            ","        } catch EmrtdReaderError.tagConnectionLost {","            showError(\"Connection lost. Please hold your passport steady and try again.\")","            ","        } catch EmrtdConnectorError.connectionFailed {","            showError(\"Could not connect to server. Please check your internet connection.\")","            ","        } catch EmrtdConnectorError.serverError(let code, let message, let reason) {","            \/\/ Handle specific server errors with parsed reasons","            if let reason = reason {","                switch reason {","                case .invalidClientId:","                    showError(\"Invalid client ID. Please check your configuration.\")","                case .accessControlFailed:","                    showError(\"Access denied. Please check your document details.\")","                case .invalidAccessKeyValues:","                    showError(\"Invalid document details. Please check the format.\")","                case .nfcChipCommunicationFailed:","                    showError(\"Lost connection to document. Please try again.\")","                default:","                    showError(reason.localizedDescription)","                }","            } else {","                showError(message ?? \"Server error \\(code)\")","            }","            ","        } catch is CancellationError {","            \/\/ User cancelled - no need to show error","            print(\"Operation cancelled by user\")","            ","        } catch {","            showError(\"An unexpected error occurred: \\(error.localizedDescription)\")","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Retry-Strategy","text":"Retry Strategy","level":2,"type":"heading"},{"inlineContent":[{"text":"For transient errors, implement retry logic in your application:","type":"text"}],"type":"paragraph"},{"code":["func validateWithRetry(maxAttempts: Int = 3) async throws -> ValidationResult {","    var lastError: Error?","    ","    for attempt in 1...maxAttempts {","        do {","            return try await connector.validate(with: accessKey)","        } catch {","            lastError = error","            ","            \/\/ Don't retry certain errors","            if error is CancellationError ||","               (error as? EmrtdReaderError)?.code == .accessControlFailed {","                throw error","            }","            ","            \/\/ Wait before retry","            if attempt < maxAttempts {","                try await Task.sleep(nanoseconds: 1_000_000_000) \/\/ 1 second","            }","        }","    }","    ","    throw lastError ?? EmrtdConnectorError.unknown","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Timeout-Handling","text":"Timeout Handling","level":2,"type":"heading"},{"inlineContent":[{"text":"iOS limits NFC sessions to 20 seconds. Handle timeouts gracefully:","type":"text"}],"type":"paragraph"},{"code":["connector.delegate = self","","func connector(_ connector: EmrtdConnector, didUpdateNFCStatus status: NFCProgressStatus) async {","    \/\/ Show progress to user","    updateUI(with: status.alertMessage)","    ","    \/\/ Warn if taking too long","    if status.step == .readingDG2 {","        showWarning(\"Please hold passport steady...\")","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Error-Recovery","text":"Error Recovery","level":2,"type":"heading"},{"anchor":"Clean-Up-After-Errors","text":"Clean Up After Errors","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The SDK automatically cleans up on errors, but you can ensure proper cleanup:"}],"type":"paragraph"},{"code":["defer {","    Task {","        await connector.disconnect()","    }","}","","do {","    let result = try await connector.validate(with: accessKey)","    \/\/ Process result","} catch {","    \/\/ Error is thrown after cleanup","    handleError(error)","}"],"syntax":"swift","type":"codeListing"},{"anchor":"User-Friendly-Error-Messages","text":"User-Friendly Error Messages","level":3,"type":"heading"},{"code":["extension Error {","    var userFriendlyMessage: String {","        switch self {","        case EmrtdConnectorError.nfcNotAvailable:","            return \"This device doesn't support NFC\"","        case EmrtdConnectorError.connectionTimeout:","            return \"Reading took too long. Please try again.\"","        case EmrtdConnectorError.incompleteRead:","            return \"Could not read all required passport data. Please try again.\"","        case EmrtdConnectorError.serverError(_, _, let reason?):","            return reason.localizedDescription","        case EmrtdReaderError.accessControlFailed:","            return \"Could not access passport. Please check the details you entered.\"","        case EmrtdReaderError.tagConnectionLost:","            return \"Lost connection. Please hold your passport still.\"","        default:","            return \"Something went wrong. Please try again.\"","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Debugging","text":"Debugging","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Debug logging is automatically enabled in DEBUG builds. The logs will show:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"WebSocket messages","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"State transitions","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"NFC operations","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Error details","type":"text"}]}]}]},{"type":"heading","level":2,"anchor":"Common-Issues-and-Solutions","text":"Common Issues and Solutions"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Error"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cause"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Solution"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"accessControlFailed","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Wrong MRZ\/CAN","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Double-check document details","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"connectionTimeout"}]}],[{"type":"paragraph","inlineContent":[{"text":"Slow connection or movement","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Use stable WiFi, hold passport steady","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"tagConnectionLost"}]}],[{"type":"paragraph","inlineContent":[{"text":"Passport moved","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Keep passport still during reading"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"incompleteRead","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Required files missing (e.g., DG2)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hold passport steady throughout entire process"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"nfcNotAvailable","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"NFC disabled or unavailable","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check device settings"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"protocolError"}]}],[{"type":"paragraph","inlineContent":[{"text":"Server compatibility","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Check server version\/configuration","type":"text"}]}]]],"header":"row"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/kinegramemrtdconnector\/handlingerrors"]}],"sections":[],"abstract":[{"type":"text","text":"Learn how to handle errors and edge cases in the eMRTD Connector V2."}],"hierarchy":{"paths":[["doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector"]]},"identifier":{"url":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/HandlingErrors","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://com.kinegram.ios.emrtdconnector/documentation/KinegramEmrtdConnector":{"type":"topic","title":"KinegramEmrtdConnector","abstract":[