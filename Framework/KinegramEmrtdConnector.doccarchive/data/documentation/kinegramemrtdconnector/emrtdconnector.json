{"hierarchy":{"paths":[["doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector"]]},"abstract":[{"text":"Main entry point for the eMRTD Connector v2 SDK","type":"text"}],"variants":[{"paths":["\/documentation\/kinegramemrtdconnector\/emrtdconnector"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"EmrtdConnector"}],"languages":["swift"],"platforms":["iOS"]}]},{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Modern iOS SDK for KINEGRAM eMRTD verification using the v2 WebSocket protocol.","type":"text"}]},{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The eMRTD Connector enables your iOS app to read and verify electronic passports and ID cards (eMRTDs) through the "},{"type":"reference","identifier":"https:\/\/kta.pages.kurzdigital.com\/kta-kinegram-document-validation-service\/","isActive":true},{"type":"text","text":". This SDK implements a “fat client” architecture that performs most processing locally while maintaining server-side security validation."}]},{"type":"codeListing","code":["    ┌───────────────┐     Results     ┌─────────────────┐","    │ DocVal Server │────────────────▶│   Your Server   │","    └───────────────┘                 └─────────────────┘","            ▲","            │ WebSocket v2","            ▼","┏━━━━━━━━━━━━━━━━━━━━━━━━┓","┃                        ┃","┃  eMRTD Connector       ┃","┃                        ┃","┗━━━━━━━━━━━━━━━━━━━━━━━━┛","            ▲","            │ NFC","            ▼","    ┌──────────────┐","    │              │","    │   PASSPORT   │","    │              │","    │   ID CARD    │","    │              │","    │              │","    │   (eMRTD)    │","    │              │","    └──────────────┘"],"syntax":null},{"level":2,"anchor":"Why-V2","type":"heading","text":"Why V2?"},{"type":"paragraph","inlineContent":[{"type":"text","text":"V2 solves the iOS 20-second NFC timeout issue by moving most APDU exchanges to the device. Instead of relaying every APDU through the server (causing latency to accumulate), V2 performs bulk reading locally and uses the server only for security-critical operations."}]},{"level":2,"anchor":"Quick-Start","type":"heading","text":"Quick Start"},{"type":"codeListing","code":["import KinegramEmrtdConnector","","\/\/ Initialize the connector","let connector = EmrtdConnector(","    serverURL: URL(string: \"wss:\/\/server.example.com\/ws2\/validate\")!,","    validationId: UUID().uuidString,","    clientId: \"YOUR-CLIENT-ID\"",")","","\/\/ Simple one-call validation","let mrzKey = MRZKey(","    documentNumber: \"P1234567\",","    birthDateyyMMdd: \"900101\",","    expiryDateyyMMdd: \"250101\"",")","","let result = try await connector.validate(with: mrzKey)","","if result.isValid {","    print(\"Document holder: \\(result.mrzInfo?.primaryIdentifier ?? \"\")\")","}"],"syntax":"swift"},{"level":2,"anchor":"Automatic-PACE-Selection","type":"heading","text":"Automatic PACE Selection"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you provide the document type and issuing country, the SDK decides whether to enable PACE polling automatically."}]},{"type":"codeListing","code":["\/\/ Auto-select PACE polling for FRA ID card","let canKey = CANKey(can: \"123456\")","let result = try await connector.validate(","    with: canKey,","    documentType: .idCard,","    issuingCountry: \"FRA\" \/\/ ISO 3166-1 alpha-3",")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"You can also derive the document type directly from the MRZ document code prefix:","type":"text"}]},{"type":"codeListing","code":["\/\/ \"ID\" or \"I<\" -> .idCard; otherwise .passport (e.g., \"P<\", \"PM\")","let docType = DocumentKind.fromMRZDocumentCode(\"ID\")","let result2 = try await connector.validate(","    with: canKey,","    documentType: docType,","    issuingCountry: \"FRA\"",")"],"syntax":"swift"}],"kind":"content"}],"sections":[],"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/MonitoringDelegate","doc:\/\/com.kinegram.ios.emrtdconnector\/s8CopyableP"]}],"metadata":{"modules":[{"name":"KinegramEmrtdConnector"}],"role":"symbol","symbolKind":"class","title":"EmrtdConnector","externalID":"s:22KinegramEmrtdConnector0bC0C","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"EmrtdConnector"}],"navigatorTitle":[{"text":"EmrtdConnector","kind":"identifier"}],"roleHeading":"Class"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","identifier":{"url":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/EmrtdConnector","interfaceLanguage":"swift"},"topicSections":[{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/EmrtdConnector\/init(serverURL:validationId:clientId:httpHeaders:enableDiagnostics:receiveResult:)"]},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/EmrtdConnector\/delegate","doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/EmrtdConnector\/isConnected","doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/EmrtdConnector\/monitoringDelegate","doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/EmrtdConnector\/nfcStatusLocalization"]},{"generated":true,"anchor":"Instance-Methods","title":"Instance Methods","identifiers":["doc:\/\/com.kinegram.ios.emrt