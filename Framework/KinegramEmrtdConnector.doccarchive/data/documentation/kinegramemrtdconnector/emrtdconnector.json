 app to read and verify electronic passports and ID cards (eMRTDs) through the "},{"type":"reference","identifier":"https:\/\/kta.pages.kurzdigital.com\/kta-kinegram-document-validation-service\/","isActive":true},{"type":"text","text":". This SDK implements a “fat client” architecture that performs most processing locally while maintaining server-side security validation."}]},{"syntax":null,"code":["    ┌───────────────┐     Results     ┌─────────────────┐","    │ DocVal Server │────────────────▶│   Your Server   │","    └───────────────┘                 └─────────────────┘","            ▲","            │ WebSocket v2","            ▼","┏━━━━━━━━━━━━━━━━━━━━━━━━┓","┃                        ┃","┃  eMRTD Connector       ┃","┃                        ┃","┗━━━━━━━━━━━━━━━━━━━━━━━━┛","            ▲","            │ NFC","            ▼","    ┌──────────────┐","    │              │","    │   PASSPORT   │","    │              │","    │   ID CARD    │","    │              │","    │              │","    │   (eMRTD)    │","    │              │","    └──────────────┘"],"type":"codeListing"},{"type":"heading","text":"Why V2?","anchor":"Why-V2","level":2},{"inlineContent":[{"text":"V2 solves the iOS 20-second NFC timeout issue by moving most APDU exchanges to the device. Instead of relaying every APDU through the server (causing latency to accumulate), V2 performs bulk reading locally and uses the server only for security-critical operations.","type":"text"}],"type":"paragraph"},{"text":"Quick Start","type":"heading","level":2,"anchor":"Quick-Start"},{"syntax":"swift","type":"codeListing","code":["import KinegramEmrtdConnector","","\/\/ Initialize the connector","let connector = EmrtdConnector(","    serverURL: URL(string: \"wss:\/\/server.example.com\/ws2\/validate\")!,","    validationId: UUID().uuidString,","    clientId: \"YOUR-CLIENT-ID\"",")","","\/\/ Simple one-call validation","let mrzKey = MRZKey(","    documentNumber: \"P1234567\",","    birthDateyyMMdd: \"900101\",","    expiryDateyyMMdd: \"250101\"",")","","let result = try await connector.validate(with: mrzKey)","","if result.isValid {","    print(\"Document holder: \\(result.mrzInfo?.primaryIdentifier ?? \"\")\")","}"]},{"text":"Automatic PACE Selection","type":"heading","level":2,"anchor":"Automatic-PACE-Selection"},{"inlineContent":[{"type":"text","text":"If you provide the document type and issuing country, the SDK decides whether to enable PACE polling automatically."}],"type":"paragraph"},{"code":["\/\/ Auto-select PACE polling for FRA ID card","let canKey = CANKey(can: \"123456\")","let result = try await connector.validate(","    with: canKey,","    documentType: .idCard,","    issuingCountry: \"FRA\" \/\/ ISO 3166-1 alpha-3",")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"You can also derive the document type directly from the MRZ document code prefix:","type":"text"}]},{"code":["\/\/ \"ID\" or \"I<\" -> .idCard; otherwise .passport (e.g., \"P<\", \"PM\")","let docType = DocumentKind.fromMRZDocumentCode(\"ID\")","let result2 = try await connector.validate(","    with: canKey,","    documentType: docType,","    issuingCountry: \"FRA\"",")"],"type":"codeListing","syntax":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/EmrtdConnector"},"references":{"doc://com.kinegram.ios.emrtdconnector/documentation/KinegramEmrtdConnector/EmrtdConnector/delegate":{"title":"delegate","type":"topic","url":"\/documentation\/kinegramemrtdconnector\/emrtdconnector\/delegate","kind":"symbol","abstract":[{"type":"text","text":"Delegate for validation events"}],"identifier":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/EmrtdConnector\/delegate","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"delegate"},{"kind":"tex