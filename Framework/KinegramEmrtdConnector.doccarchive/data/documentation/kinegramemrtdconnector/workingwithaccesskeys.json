{"abstract":[{"type":"text","text":"Learn how to use MRZ and CAN access keys to read eMRTD documents."}],"hierarchy":{"paths":[["doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector"]]},"metadata":{"roleHeading":"Article","role":"article","title":"Working with Access Keys","modules":[{"name":"KinegramEmrtdConnector"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/kinegramemrtdconnector\/workingwithaccesskeys"]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/WorkingWithAccessKeys"},"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"To access an eMRTD chip, you need to provide authentication credentials. The SDK supports two types of access keys:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"MRZ Key","type":"text"}],"type":"strong"},{"text":": Using document number, date of birth, and date of expiry from the Machine Readable Zone","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"CAN Key","type":"text"}]},{"text":": Using the Card Access Number printed on the document","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"MRZ-Key","level":2,"type":"heading","text":"MRZ Key"},{"inlineContent":[{"type":"text","text":"The MRZ (Machine Readable Zone) contains the document information printed at the bottom of passports and ID cards."}],"type":"paragraph"},{"anchor":"Creating-an-MRZ-Key","level":3,"type":"heading","text":"Creating an MRZ Key"},{"syntax":"swift","code":["let mrzKey = MRZKey(","    documentNumber: \"P1234567\",","    birthDateyyMMdd: \"900515\",    \/\/ Format: yyMMdd","    expiryDateyyMMdd: \"251231\"    \/\/ Format: yyMMdd",")"],"type":"codeListing"},{"anchor":"Date-Format","level":3,"type":"heading","text":"Date Format"},{"inlineContent":[{"text":"Dates must be provided in ","type":"text"},{"code":"yyMMdd","type":"codeVoice"},{"text":" format:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"\"900515\""},{"type":"text","text":" = May 15, 1990"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"\"251231\"","type":"codeVoice"},{"text":" = December 31, 2025","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"\"010101\"","type":"codeVoice"},{"text":" = January 1, 2001","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Document-Number","level":3,"type":"heading","text":"Document Number"},{"inlineContent":[{"text":"The document number should be provided exactly as it appears in the MRZ:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Remove any spaces"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Include check digits if present","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Maximum 9 characters"}]}]}],"type":"unorderedList"},{"anchor":"Example-from-MRZ","level":3,"type":"heading","text":"Example from MRZ"},{"inlineContent":[{"type":"text","text":"Given this MRZ:"}],"type":"paragraph"},{"syntax":null,"code":["P<UTOERIKSSON<<ANNA<MARIA<<<<<<<<<<<<<<<<<<<","L898902C36UTO7408122F1204159ZE184226B<<<<<10"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Extract:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Document Number: "},{"type":"codeVoice","code":"L898902C3"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Birth Date: "},{"type":"codeVoice","code":"740812"},{"type":"text","text":" (August 12, 1974)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Expiry Date: ","type":"text"},{"type":"codeVoice","code":"120415"},{"text":" (April 15, 2012)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"CAN-Key","level":2,"type":"heading","text":"CAN Key"},{"inlineContent":[{"text":"The CAN (Card Access Number) is a 6-digit number printed on the document, typically on the front of ID cards.","type":"text"}],"type":"paragraph"},{"anchor":"Creating-a-CAN-Key","level":3,"type":"heading","text":"Creating a CAN Key"},{"syntax":"swift","code":["let canKey = CANKey(can: \"123456\")"],"type":"codeListing"},{"anchor":"CAN-Format","level":3,"type":"heading","text":"CAN Format"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Exactly 6 digits"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"No spaces or separators","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Usually printed near the document number"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Choosing-Between-MRZ-and-CAN","level":2,"type":"heading","text":"Choosing Between MRZ and CAN"},{"anchor":"Use-MRZ-when","level":3,"type":"heading","text":"Use MRZ when:"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Working with passports (always have MRZ)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You have OCR capabilities to read the MRZ"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Users are familiar with their document details"}]}]}],"type":"unorderedList"},{"anchor":"Use-CAN-when","level":3,"type":"heading","text":"Use CAN when:"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Working with ID cards that have CAN"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"You want a simpler user experience (just 6 digits)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The CAN is clearly visible on the document"}]}]}],"type":"unorderedList"},{"anchor":"Access-Control-Protocols","level":2,"type":"heading","text":"Access Control Protocols"},{"inlineContent":[{"type":"text","text":"The SDK automatically selects the appropriate access control protocol:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"BAC"}],"type":"strong"},{"text":" (Basic Access Control): Older passports","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"PACE","type":"text"}],"type":"strong"},{"text":" (Password Authenticated Connection Establishment): Newer passports and ID cards","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Both MRZ and CAN keys can use either protocol - the SDK handles this automatically."}],"type":"paragraph"},{"anchor":"Usage-Example","level":2,"type":"heading","text":"Usage Example"},{"syntax":"swift","code":["\/\/ Using MRZ","let mrzKey = MRZKey(","    documentNumber: \"P1234567\",","    birthDateyyMMdd: \"900101\",","    expiryDateyyMMdd: \"250101\"",")","","let result = try await connector.validate(with: mrzKey)","","\/\/ Using CAN","let canKey = CANKey(can: \"123456\")","let result = try await connector.validate(with: canKey)"],"type":"codeListing"},{"anchor":"Error-Handling","level":2,"type":"heading","text":"Error Handling"},{"inlineContent":[{"text":"Common access key errors:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["do {","    let result = try await connector.validate(with: accessKey)","} catch EmrtdReaderError.accessControlFailed {","    \/\/ Wrong access key - check MRZ\/CAN values","} catch EmrtdReaderError.invalidAccessKey {","    \/\/ Malformed access key","} catch {","    \/\/ Other errors","}"],"type":"codeListing"},{"anchor":"Security-Considerations","level":2,"type":"heading","text":"Security Considerations"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Never log or store access keys in plain text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Access keys are sensitive personal data"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Clear from memory after use"}]}]},{"content":[{"inlineContent":[{"text":"Use secure input methods in your UI","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"kind":"article","references":{"doc://com.kinegram.ios.emrtdconnector/documentation/KinegramEmrtdConnector":{"role":"collection","kind":"symbol","title":"KinegramEmrtdConnector","url":"\/documentation\/kinegramemrtdconnector","abstract":[],"identifier":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector","type":"topic"}}}