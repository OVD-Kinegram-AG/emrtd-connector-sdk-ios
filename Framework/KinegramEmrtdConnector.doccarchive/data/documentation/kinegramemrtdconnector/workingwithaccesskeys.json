{"abstract":[{"type":"text","text":"Learn how to use MRZ and CAN access keys to read eMRTD documents."}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To access an eMRTD chip, you need to provide authentication credentials. The SDK supports two types of access keys:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"MRZ Key"}]},{"type":"text","text":": Using document number, date of birth, and date of expiry from the Machine Readable Zone"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"CAN Key"}]},{"type":"text","text":": Using the Card Access Number printed on the document"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"MRZ-Key","type":"heading","text":"MRZ Key"},{"type":"paragraph","inlineContent":[{"text":"The MRZ (Machine Readable Zone) contains the document information printed at the bottom of passports and ID cards.","type":"text"}]},{"level":3,"anchor":"Creating-an-MRZ-Key","type":"heading","text":"Creating an MRZ Key"},{"type":"codeListing","code":["let mrzKey = MRZKey(","    documentNumber: \"P1234567\",","    birthDateyyMMdd: \"900515\",    \/\/ Format: yyMMdd","    expiryDateyyMMdd: \"251231\"    \/\/ Format: yyMMdd",")"],"syntax":"swift"},{"level":3,"anchor":"Date-Format","type":"heading","text":"Date Format"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Dates must be provided in "},{"code":"yyMMdd","type":"codeVoice"},{"type":"text","text":" format:"}]},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"\"900515\""},{"type":"text","text":" = May 15, 1990"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"\"251231\"","type":"codeVoice"},{"type":"text","text":" = December 31, 2025"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"010101\""},{"type":"text","text":" = January 1, 2001"}]}]}],"type":"unorderedList"},{"level":3,"anchor":"Document-Number","type":"heading","text":"Document Number"},{"type":"paragraph","inlineContent":[{"text":"The document number should be provided exactly as it appears in the MRZ:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Remove any spaces"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Include check digits if present","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Maximum 9 characters","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"anchor":"Example-from-MRZ","type":"heading","text":"Example from MRZ"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Given this MRZ:"}]},{"type":"codeListing","code":["P<UTOERIKSSON<<ANNA<MARIA<<<<<<<<<<<<<<<<<<<","L898902C36UTO7408122F1204159ZE184226B<<<<<10"],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"Extract:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Document Number: "},{"code":"L898902C3","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Birth Date: "},{"type":"codeVoice","code":"740812"},{"type":"text","text":" (August 12, 1974)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Expiry Date: "},{"type":"codeVoice","code":"120415"},{"type":"text","text":" (April 15, 2012)"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"CAN-Key","type":"heading","text":"CAN Key"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The CAN (Card Access Number) is a 6-digit number printed on the document, typically on the front of ID cards."}]},{"level":3,"anchor":"Creating-a-CAN-Key","type":"heading","text":"Creating a CAN Key"},{"type":"codeListing","code":["let canKey = CANKey(can: \"123456\")"],"syntax":"swift"},{"level":3,"anchor":"CAN-Format","type":"heading","text":"CAN Format"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Exactly 6 digits","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"No spaces or separators"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Usually printed near the document number"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Choosing-Between-MRZ-and-CAN","type":"heading","text":"Choosing Between MRZ and CAN"},{"level":3,"anchor":"Use-MRZ-when","type":"heading","text":"Use MRZ when:"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Working with passports (always have MRZ)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"You have OCR capabilities to read the MRZ","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Users are familiar with their document details"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"anchor":"Use-CAN-when","type":"heading","text":"Use CAN when:"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Working with ID cards that have CAN","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"You want a simpler user experience (just 6 digits)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The CAN is clearly visible on the document","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Access-Control-Protocols","type":"heading","text":"Access Control Protocols"},{"type":"paragraph","inlineContent":[{"text":"The SDK automatically selects the appropriate access control protocol:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"BAC","type":"text"}]},{"type":"text","text":" (Basic Access Control): Older passports"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"PACE","type":"text"}],"type":"strong"},{"type":"text","text":" (Password Authenticated Connection Establishment): Newer passports and ID cards"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both MRZ and CAN keys can use either protocol - the SDK handles this automatically."}]},{"level":2,"anchor":"Usage-Example","type":"heading","text":"Usage Example"},{"type":"codeListing","code":["\/\/ Using MRZ","let mrzKey = MRZKey(","    documentNumber: \"P1234567\",","    birthDateyyMMdd: \"900101\",","    expiryDateyyMMdd: \"250101\"",")","","let result = try await connector.validate(with: mrzKey)","","\/\/ Using CAN","let canKey = CANKey(can: \"123456\")","let result = try await connector.validate(with: canKey)"],"syntax":"swift"},{"level":2,"anchor":"Error-Handling","type":"heading","text":"Error Handling"},{"type":"paragraph","inlineContent":[{"text":"Common access key errors:","type":"text"}]},{"type":"codeListing","code":["do {","    let result = try await connector.validate(with: accessKey)","} catch EmrtdReaderError.accessControlFailed {","    \/\/ Wrong access key - check MRZ\/CAN values","} catch EmrtdReaderError.invalidAccessKey {","    \/\/ Malformed access key","} catch {","    \/\/ Other errors","}"],"syntax":"swift"},{"level":2,"anchor":"Security-Considerations","type":"heading","text":"Security Considerations"},{"items":[{"content":[{"inlineContent":[{"text":"Never log or store access keys in plain text","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Access keys are sensitive personal data"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Clear from memory after use","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Use secure input methods in your UI"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/WorkingWithAccessKeys","interfaceLanguage":"swift"},"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/kinegramemrtdconnector\/workingwithaccesskeys"]}],"sections":[],"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"KinegramEmrtdConnector"}],"title":"Working with Access Keys"},"hierarchy":{"paths":[["doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector"]]},"references":{"doc://com.kinegram.ios.emrtdconnector/documentation/KinegramEmrtdConnector":{"abstract":[],"type":"topic","url":"\/documentation\/kinegramemrtdconnector","identifier":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector","kind":"symbol","title":"KinegramEmrtdConnector","role":"collection"}}}