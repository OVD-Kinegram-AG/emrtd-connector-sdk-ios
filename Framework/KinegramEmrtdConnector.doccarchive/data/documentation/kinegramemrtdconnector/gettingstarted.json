{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/GettingStarted"},"metadata":{"modules":[{"name":"KinegramEmrtdConnector"}],"role":"article","roleHeading":"Article","title":"Getting Started"},"abstract":[{"type":"text","text":"Quick integration guide for the eMRTD Connector SDK."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/kinegramemrtdconnector\/gettingstarted"]}],"kind":"article","sections":[],"hierarchy":{"paths":[["doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Installation","anchor":"Installation"},{"type":"paragraph","inlineContent":[{"text":"Add the package via Swift Package Manager using the repository URL provided by KINEGRAM.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Requirements:"}]},{"text":" iOS 15.0+, Swift 5.5+, Physical device with NFC","type":"text"}]},{"type":"heading","level":2,"text":"Setup Your App: Requirements Setup","anchor":"Setup-Your-App-Requirements-Setup"},{"type":"heading","level":3,"text":"1. Enable NFC Capability","anchor":"1-Enable-NFC-Capability"},{"type":"paragraph","inlineContent":[{"text":"This needed entitlement is added automatically by Xcode when enabling the","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"Near Field Communication Tag Reading","type":"text"}],"type":"strong"},{"text":" capability in the target","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Signing & Capabilities"}],"type":"strong"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"After enabling the capability the ","type":"text"},{"type":"codeVoice","code":"*.entitlements"},{"text":" file needs to contain","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"TAG"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"(Application specific tag, including ISO 7816 Tags)"}]},{"text":" and ","type":"text"},{"type":"codeVoice","code":"PACE"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"(Needed for PACE polling support (some ID cards))","type":"text"}]},{"text":" format:","type":"text"}],"type":"paragraph"},{"syntax":"xml","code":["...","<dict>","    <key>com.apple.developer.nfc.readersession.formats<\/key>","    <array>","        <string>PACE<\/string>","        <string>TAG<\/string>","    <\/array>","<\/dict>","..."],"type":"codeListing"},{"text":"2. Info.plist (AID & NFCReaderUsageDescription)","anchor":"2-Infoplist-AID--NFCReaderUsageDescription","level":3,"type":"heading"},{"inlineContent":[{"text":"The app needs to define the list of ","type":"text"},{"code":"AIDs","type":"codeVoice"},{"text":" it can connect to, in the ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"text":" file.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"AID","type":"codeVoice"},{"text":" is a way of uniquely identifying an application on a ISO 7816 tag.","type":"text"},{"text":" ","type":"text"},{"text":"eMRTDS use the AIDs ","type":"text"},{"code":"A0000002471001","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"A0000002472001","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Your ","type":"text"},{"inlineContent":[{"type":"text","text":"Info.plist"}],"type":"emphasis"},{"text":" entry should look like this:","type":"text"}],"type":"paragraph"},{"syntax":"xml","code":["    <key>com.apple.developer.nfc.readersession.iso7816.select-identifiers<\/key>","    <array>","        <string>A0000002471001<\/string>","        <string>A0000002472001<\/string>","    <\/array>"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Additionally set the "},{"type":"codeVoice","code":"NFCReaderUsageDescription"},{"type":"text","text":" key:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":"xml","code":["    <key>NFCReaderUsageDescription<\/key>","    <string>This app uses NFC to verify passports<\/string>"],"type":"codeListing"},{"text":"Basic Implementation","anchor":"Basic-Implementation","level":2,"type":"heading"},{"text":"Simple One-Call Validation","anchor":"Simple-One-Call-Validation","level":3,"type":"heading"},{"syntax":"swift","code":["import KinegramEmrtdConnector","","class DocumentValidator {","    func validateDocument() async {","        \/\/ Create connector","        let connector = EmrtdConnector(","            serverURL: URL(string: \"wss:\/\/server.example.com\/ws2\/validate\")!,","            validationId: UUID().uuidString,","            clientId: \"YOUR-CLIENT-ID\"","        )","        ","        \/\/ Create access key (MRZ or CAN)","        let mrzKey = MRZKey(","            documentNumber: \"P1234567\",","            birthDateyyMMdd: \"900101\",","            expiryDateyyMMdd: \"250101\"","        )","        ","        do {","            \/\/ Validate - connection and disconnection are automatic!","            let result = try await connector.validate(with: mrzKey)","            ","            if result.isValid {","                print(\"Valid document\")","                print(\"Name: \\(result.mrzInfo?.primaryIdentifier ?? \"\")\")","            } else {","                print(\"Invalid document\")","            }","        } catch {","            print(\"Validation failed: \\(error)\")","        }","    }","}"],"type":"codeListing"},{"level":3,"type":"heading","text":"With Progress Updates","anchor":"With-Progress-Updates"},{"type":"codeListing","syntax":"swift","code":["import KinegramEmrtdConnector","","class DocumentValidator: EmrtdConnectorDelegate {","    private var connector: EmrtdConnector?","    ","    func validateDocument() async {","        connector = EmrtdConnector(","            serverURL: URL(string: \"wss:\/\/server.example.com\/ws2\/validate\")!,","            validationId: UUID().uuidString,","            clientId: \"YOUR-CLIENT-ID\"","        )","        ","        \/\/ Set delegate for progress updates","        connector?.delegate = self","        ","        let canKey = CANKey(can: \"123456\")","        ","        do {","            let result = try await connector?.validate(with: canKey)","            \/\/ Handle result...","        } catch {","            \/\/ Handle error...","        }","    }","    ","    \/\/ MARK: - EmrtdConnectorDelegate","    ","    func connector(_ connector: EmrtdConnector, didUpdateNFCStatus status: NFCProgressStatus) async {","        print(\"NFC Status: \\(status.alertMessage)\")","        \/\/ Update UI with progress...","    }","    ","    func connector(_ connector: EmrtdConnector, didFailWithError error: Error) async {","        print(\"Error: \\(error)\")","    }","}"]},{"level":3,"type":"heading","text":"Reading PACE-enabled Documents","anchor":"Reading-PACE-enabled-Documents"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some identity documents require PACE (Password Authenticated Connection Establishment) polling to be detected. This includes French ID cards (FRA ID) and Omani ID cards (OMN ID)."}]},{"type":"codeListing","syntax":"swift","code":["import KinegramEmrtdConnector","","class DocumentValidator {","    func validatePACEDocument() async {","        let connector = EmrtdConnector(","            serverURL: URL(string: \"wss:\/\/server.example.com\/ws2\/validate\")!,","            validationId: UUID().uuidString,","            clientId: \"YOUR-CLIENT-ID\"","        )","","        let canKey = CANKey(can: \"123456\")","","        do {","            \/\/ Enable PACE polling for PACE-enabled documents (requires iOS 16+)","            let result = try await connector.validate(with: canKey, usePACEPolling: true)","","            if result.isValid {","                print(\"Valid document\")","            }","        } catch EmrtdReaderError.PACEPollingNotAvailable {","            print(\"PACE polling requires iOS 16 or later\")","        } catch {","            print(\"Validation failed: \\(error)\")","        }","    }","}"]},{"content":[{"inlineContent":[{"text":"PACE polling is only available on iOS 16 and later. It cannot detect standard passports - use it only when you know the document requires it.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Important","style":"important"},{"level":3,"type":"heading","text":"Automatic PACE Selection (by document info)","anchor":"Automatic-PACE-Selection-by-document-info"},{"type":"paragraph","inlineContent":[{"text":"Let the SDK decide whether PACE polling is needed by providing the document type and issuing country. This enables PACE polling for known ID cards (e.g., FRA ID, OMN ID) and keeps it off for passports by default.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import KinegramEmrtdConnector","","class DocumentValidator {","    func validatePACEDocumentAutomatically() async {","        let connector = EmrtdConnector(","            serverURL: URL(string: \"wss:\/\/server.example.com\/ws2\/validate\")!,","            validationId: UUID().uuidString,","            clientId: \"YOUR-CLIENT-ID\"","        )","","        let canKey = CANKey(can: \"123456\")","","        do {","            \/\/ Auto-select PACE polling for FRA ID card (explicit document type)","            let result = try await connector.validate(","                with: canKey,","                documentType: .idCard,","                issuingCountry: \"FRA\"","            )","","            if result.isValid {","                print(\"Valid document\")","            }","        } catch EmrtdReaderError.PACEPollingNotAvailable {","            print(\"PACE polling requires iOS 16 or later\")","        } catch {","            print(\"Validation failed: \\(error)\")","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"You can also derive the document type directly from the MRZ document code prefix:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ e.g., \"ID\" or \"I<\" -> idCard; otherwise passport (e.g., \"P<\", \"PM\")","let docType = DocumentKind.fromMRZDocumentCode(\"ID\")","let result = try await connector.validate(","    with: CANKey(can: \"123456\"),","    documentType: docType,","    issuingCountry: \"FRA\"",")"]},{"type":"paragraph","inlineContent":[{"text":"Notes:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Include the "},{"type":"codeVoice","code":"PACE"},{"type":"text","text":" entitlement when PACE might be used (see Requirements Setup)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"For unknown combinations and for passports, automatic selection defaults to no PACE polling. You can still use the manual ","type":"text"},{"type":"codeVoice","code":"usePACEPolling"},{"text":" flag if required.","type":"text"}]}]}]},{"level":2,"type":"heading","text":"Custom HTTP Headers (Optional)","anchor":"Custom-HTTP-Headers-Optional"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Most users don’t need custom headers. This feature is only for specific use cases where your result server requires additional authentication or metadata. The headers will be forwarded by DocVal to your result server."}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Only if your server requires it:","let headers = [","    \"Authorization\": \"Bearer your-token\",","    \"X-Custom-Header\": \"value\"","]","","let connector = EmrtdConnector(","    serverURL: URL(string: \"wss:\/\/server.example.com\/ws2\/validate\")!,","    validationId: UUID().uuidString,","    clientId: \"YOUR-CLIENT-ID\",","    httpHeaders: headers  \/\/ Optional - most users can omit this",")"]},{"level":2,"type":"heading","text":"Custom NFC Status Messages (Optional)","anchor":"Custom-NFC-Status-Messages-Optional"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Customize or localize NFC dialog messages, including error messages:"}]},{"type":"codeListing","syntax":"swift","code":["connector.nfcStatusLocalization = { status in","    switch status.step {","    case .error:","        return \"\"  \/\/ Hide error text, show only icon","    case .waitingForPassport:","        return \"Place document on phone\"","    case .readingDG2:","        return \"Reading photo...\"","    default:","        return status.alertMessage  \/\/ Use default","    }","}"]},{"level":2,"type":"heading","text":"Diagnostics and Monitoring","anchor":"Diagnostics-and-Monitoring"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SDK provides built-in diagnostics and monitoring capabilities for debugging and telemetry purposes."}]},{"level":3,"type":"heading","text":"Enable Diagnostics Mode","anchor":"Enable-Diagnostics-Mode"},{"type":"paragraph","inlineContent":[{"text":"To enable diagnostic data collection and transmission to the server:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let connector = EmrtdConnector(","    serverURL: URL(string: \"wss:\/\/server.example.com\/ws2\/validate\")!,","    validationId: UUID().uuidString,","    clientId: \"YOUR-CLIENT-ID\",","    enableDiagnostics: true  \/\/ Enable diagnostic data transmission",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When enabled, diagnostic messages are automatically sent to the DocVal server for analysis."}]},{"level":3,"type":"heading","text":"Monitoring Delegate","anchor":"Monitoring-Delegate"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For local monitoring and debugging, implement the "},{"type":"codeVoice","code":"EmrtdConnectorMonitoringDelegate"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["class MyMonitoringHandler: EmrtdConnectorMonitoringDelegate {","    func connector(_ connector: EmrtdConnector, ","                   didReceiveMonitoringMessage message: String) async {","        \/\/ Log monitoring events for debugging","        print(\"[MONITORING] \\(message)\")","        ","        \/\/ You can also:","        \/\/ - Save to a log file","        \/\/ - Send to your analytics service","        \/\/ - Display in a debug console","    }","}","","\/\/ Set the monitoring delegate","connector.monitoringDelegate = myMonitoringHandler"]},{"level":3,"type":"heading","text":"What Monitoring Data Includes","anchor":"What-Monitoring-Data-Includes"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The monitoring messages include:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"NFC communication details"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Error details and stack traces"}]}]}]},{"level":3,"type":"heading","text":"Important Notes","anchor":"Important-Notes"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Performance","type":"text"}],"type":"strong"},{"text":": Monitoring has minimal performance impact but generates additional network traffic when ","type":"text"},{"code":"enableDiagnostics","type":"codeVoice"},{"text":" is true.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Server Support","type":"text"}]},{"type":"text","text":": The "},{"code":"enableDiagnostics","type":"codeVoice"},{"type":"text","text":" flag requires server-side support for receiving diagnostic messages (from DocVal version 1.9.0+)"}]}]}]},{"level":2,"type":"heading","text":"Next Steps","anchor":"Next-Steps"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/WorkingWithAccessKeys"},{"type":"text","text":" for MRZ and CAN details"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/HandlingErrors","isActive":true,"type":"reference"},{"text":" for comprehensive error handling","type":"text"}],"type":"paragraph"}]}]}]}],"references":{"doc://com.kinegram.ios.emrtdconnector/documentation/KinegramEmrtdConnector":{"abstract":[],"type":"topic","url":"\/documentation\/kinegramemrtdconnector","identifier":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector","kind":"symbol","title":"KinegramEmrtdConnector","role":"collection"},"doc://com.kinegram.ios.emrtdconnector/documentation/KinegramEmrtdConnector/HandlingErrors":{"role":"article","url":"\/documentation\/kinegramemrtdconnector\/handlingerrors","abstract":[{"type":"text","text":"Learn how to handle errors and edge cases in the eMRTD Connector V2."}],"identifier":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/HandlingErrors","title":"Handling Errors","type":"topic","kind":"article"},"doc://com.kinegram.ios.emrtdconnector/documentation/KinegramEmrtdConnector/WorkingWithAccessKeys":{"title":"Working with Access Keys","url":"\/documentation\/kinegramemrtdconnector\/workingwithaccesskeys","type":"topic","abstract":[{"type":"text","text":"Learn how to use MRZ and CAN access keys to read eMRTD documents."}],"kind":"article","identifier":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/WorkingWithAccessKeys","role":"article"}}}