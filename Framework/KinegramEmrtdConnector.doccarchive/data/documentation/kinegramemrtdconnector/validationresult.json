ontent":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Verifies data integrity: ensures passport data hasn’t been modified"}]}]},{"content":[{"inlineContent":[{"text":"Checks the digital signature on the passport data (SOD file)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Uses PKI certificates to validate the issuing country’s signature","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Result: “SUCCEEDED” = data is intact, “FAILED” = data may be tampered"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Chip Authentication (CA)"}],"type":"strong"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Verifies chip authenticity: ensures the chip is genuine, not cloned"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Chip proves it has the private key matching the public key in DG14"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Establishes new secure messaging keys for enhanced protection","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Result: “SUCCEEDED” = genuine chip, “FAILED” = possible clone","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Active Authentication (AA)"}]}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Proves the chip is not a copy at this moment","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Chip signs a challenge with its private key (from DG15)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Like asking the chip to solve a unique puzzle only it can solve","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Result: “SUCCEEDED” = original chip responding, “FAILED” = possible replay"}]}]}]},{"type":"heading","text":"Why All Three?","level":2,"anchor":"Why-All-Three"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"PA: Ensures data wasn’t changed (like a tamper-evident seal)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"CA: Ensures chip is genuine (like a hologram)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"AA: Ensures chip is responding live (like a live video call vs recording)"}],"type":"paragraph"}]}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/kinegramemrtdconnector\/validationresult"]}],"references":{"doc://com.kinegram.ios.emrtdconnector/documentation/KinegramEmrtdConnector/ValidationResult/fireAndForgetPlaceholder()":{"identifier":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/ValidationResult\/fireAndForgetPlaceholder()","type":"topic","title":"fireAndForgetPlaceholder()","kind":"symbol","abstract":[{"type":"text","text":"Minimal placeholder for fire-and-forget mode (no RESULT expected)."}],"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fireAndForgetPlaceholder"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"ValidationResult","preciseIdentifier":"s:22KinegramEmrtdConnector16ValidationResultV"}],"url":"\/documentation\/kinegramemrtdconnector\/validationresult\/fireandforgetplaceholder()","role":"symbol"},"doc://com.kinegram.ios.emrtdconnector/documentation/KinegramEmrtdConnector/ValidationResult/errors":{"title":"errors","kind":"symbol","abstract":[],"type":"topic","url":"\/documentation\/kinegramemrtdconnector\/validationresult\/errors","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"errors","kind":"identifier"},{"text":": [","kind":"text"},{"text":"String","kind":"typeIdentifier",