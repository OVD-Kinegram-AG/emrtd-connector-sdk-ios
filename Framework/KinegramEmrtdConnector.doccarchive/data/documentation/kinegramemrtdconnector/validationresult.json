raph","inlineContent":[{"text":"Uses PKI certificates to validate the issuing country’s signature","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Result: “SUCCEEDED” = data is intact, “FAILED” = data may be tampered"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Chip Authentication (CA)","type":"text"}]}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Verifies chip authenticity: ensures the chip is genuine, not cloned","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Chip proves it has the private key matching the public key in DG14"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Establishes new secure messaging keys for enhanced protection"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Result: “SUCCEEDED” = genuine chip, “FAILED” = possible clone"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Active Authentication (AA)","type":"text"}]}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Proves the chip is not a copy at this moment","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Chip signs a challenge with its private key (from DG15)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Like asking the chip to solve a unique puzzle only it can solve"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Result: “SUCCEEDED” = original chip responding, “FAILED” = possible replay"}],"type":"paragraph"}]}]},{"type":"heading","text":"Why All Three?","anchor":"Why-All-Three","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"PA: Ensures data wasn’t changed (like a tamper-evident seal)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inli