"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Result: “SUCCEEDED” = data is intact, “FAILED” = data may be tampered"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Chip Authentication (CA)"}],"type":"strong"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Verifies chip authenticity: ensures the chip is genuine, not cloned","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Chip proves it has the private key matching the public key in DG14"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Establishes new secure messaging keys for enhanced protection"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Result: “SUCCEEDED” = genuine chip, “FAILED” = possible clone","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Active Authentication (AA)"}],"type":"strong"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Proves the chip is not a copy at this moment"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Chip signs a challenge with its private key (from DG15)","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Like asking the chip to solve a unique puzzle only it can solve","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Result: “SUCCEEDED” = original chip responding, “FAILED” = possible replay"}]}]}]},{"anchor":"Why-All-Three","text":"Why All Three?","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"PA: Ensures data wasn’t changed (like a tamper-evident seal)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"CA: Ensures chip is genuine (like a hologram)","type":"text"}]}]},{"content":[{"type":"par