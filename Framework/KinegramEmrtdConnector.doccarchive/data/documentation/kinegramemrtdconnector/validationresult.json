{"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ValidationResult"}],"role":"symbol","modules":[{"name":"KinegramEmrtdConnector"}],"title":"ValidationResult","externalID":"s:22KinegramEmrtdConnector16ValidationResultV","navigatorTitle":[{"kind":"identifier","text":"ValidationResult"}],"roleHeading":"Structure"},"abstract":[{"type":"text","text":"The final validation result from the server"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector"]]},"identifier":{"url":"doc:\/\/com.kinegram.ios.emrtdconnector\/documentation\/KinegramEmrtdConnector\/ValidationResult","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ValidationResult","kind":"identifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"This contains all passport data and the results of the three authentication protocols:"}],"type":"paragraph"},{"anchor":"Authentication-Protocols-Explained","type":"heading","level":2,"text":"Authentication Protocols Explained"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Passive Authentication (PA)"}]}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Verifies data integrity: ensures passport data hasn’t been modified"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Checks the digital signature on the passport data (SOD file)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Uses PKI certificates to validate the issuing country’s signature